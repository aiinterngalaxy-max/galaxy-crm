rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isManagement() {
      return getRole() in ['super_admin', 'management'];
    }

    function isSuperAdmin() {
      return getRole() == 'super_admin';
    }

    function isNotPending() {
      return getRole() != 'pending';
    }

    // Users collection
    match /users/{userId} {
      // Any approved (non-pending) team member can read the user directory —
      // the app needs it to populate "Assign To" / "Performed by" pickers, list
      // project workers, and route notifications. Pending users can still read
      // their own doc (needed at login, before approval). Only management can
      // change roles/status (enforced on update below).
      allow read: if isAuth() && (request.auth.uid == userId || isNotPending());

      // First login: user creates their own doc with role=pending only
      allow create: if isAuth() && request.auth.uid == userId && request.resource.data.role == 'pending';

      // Self-update: allowed but role, isActive, and department are immutable by the user
      // Only management can change those fields
      allow update: if isAuth() && (
        (
          request.auth.uid == userId
          && !('role' in request.resource.data.diff(resource.data).affectedKeys())
          && !('isActive' in request.resource.data.diff(resource.data).affectedKeys())
          && !('department' in request.resource.data.diff(resource.data).affectedKeys())
        )
        || isManagement()
      );

      allow delete: if isSuperAdmin();
    }

    // Counter document for atomic code generation (leads, quotations, projects)
    match /meta/{docId} {
      allow read, write: if isAuth() && isNotPending();
    }

    // Access Requests
    match /accessRequests/{reqId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isManagement());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isManagement();
      allow delete: if isManagement();
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAuth() && (
        isManagement() ||
        getRole() in ['dept_head', 'bd_exec', 'project_manager']
      );
      allow create, update: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'bd_exec'];
      allow delete: if isManagement();

      match /activities/{actId} {
        allow read, write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'bd_exec'];
      }
      match /documents/{docId} {
        allow read, write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'bd_exec'];
      }
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isAuth() && isNotPending();
      allow create, update: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'bd_exec', 'project_manager'];
      allow delete: if isManagement();
    }

    // Quotations
    match /quotations/{quoteId} {
      allow read: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'bd_exec', 'project_manager'];
      allow create, update: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      allow delete: if isManagement();

      match /lineItems/{itemId} {
        allow read, write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      }
    }

    // Products
    match /products/{productId} {
      allow read: if isAuth() && isNotPending();
      allow write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head'];
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
      allow create, update: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      allow delete: if isManagement();

      match /workflow/{stageId} {
        allow read: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
        allow write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      }

      match /milestones/{milestoneId} {
        allow read: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
        allow write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      }

      match /tasks/{taskId} {
        allow read: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
        allow write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      }

      // Material order lines (CSV-uploaded products mapped to inventory, with delivery tracking)
      match /orderItems/{orderItemId} {
        allow read: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
        allow write: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      }

      match /siteReports/{reportId} {
        allow read: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
        allow create: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
        allow update, delete: if isManagement();
      }

      match /issues/{issueId} {
        allow read: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
        allow create: if isAuth() && getRole() != 'marketing' && getRole() != 'pending';
        allow update: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      }
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      allow write: if isAuth() && getRole() in ['super_admin', 'management'];

      match /payments/{paymentId} {
        allow read: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head'];
        allow write: if isAuth() && getRole() in ['super_admin', 'management'];
      }
    }

    // Daily Reports
    match /dailyReports/{reportId} {
      allow read: if isAuth() && (
        isManagement() ||
        getRole() == 'dept_head' ||
        resource.data.employeeId == request.auth.uid
      );
      allow create: if isAuth() && isNotPending() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.employeeId == request.auth.uid ||
        isManagement()
      );
    }

    // AI Digests — read only for management, no client writes
    match /aiDigests/{digestId} {
      allow read: if isAuth() && isManagement();
      allow write: if false;
    }

    // Notifications
    // Any non-pending user can create (needed for cross-role notifications e.g. PM → management approval)
    // Only the recipient can read/update/delete their own notifications
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth() && isNotPending();
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }

    // Partners (B2B)
    match /partners/{partnerId} {
      allow read: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'bd_exec', 'project_manager'];
      allow create, update: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'bd_exec'];
      allow delete: if isManagement();
    }

    // Inventory
    match /inventory/{itemId} {
      allow read: if isAuth() && isNotPending();
      allow create, update: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      allow delete: if isManagement();
    }

    match /stockTransactions/{txId} {
      allow read: if isAuth() && isNotPending();
      allow create: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
      allow update, delete: if false;
    }

    // Audit Logs — read management only, no client writes
    match /auditLogs/{logId} {
      allow read: if isAuth() && isManagement();
      allow write: if false;
    }

    // App settings — e.g. the custom role→module permissions map.
    // Every approved user reads this at startup to resolve their nav/route
    // access (AuthContext); only management can change it.
    match /settings/{docId} {
      allow read: if isAuth() && isNotPending();
      allow write: if isAuth() && isManagement();
    }

    // HR — job descriptions and candidates (candidates hold resume/PII data),
    // so access is limited to HR and management.
    match /jobDescriptions/{jdId} {
      allow read, write: if isAuth() && getRole() in ['super_admin', 'management', 'hr'];
    }
    match /candidates/{candidateId} {
      allow read, write: if isAuth() && getRole() in ['super_admin', 'management', 'hr'];
    }

    // Non-working inventory — operational log managed from the Inventory module
    // by dept heads / project managers, who also remove entries (soft-delete to
    // the recycle bin), so delete matches the create/update role set.
    match /nonWorkingInventory/{itemId} {
      allow read: if isAuth() && isNotPending();
      allow create, update, delete: if isAuth() && getRole() in ['super_admin', 'management', 'dept_head', 'project_manager'];
    }

    // Recycle bin — soft-deleted items from across the app. Anyone who can
    // delete something records a trash entry; only management can view, restore,
    // or permanently remove them.
    match /deletedItems/{itemId} {
      allow read: if isAuth() && isManagement();
      allow create: if isAuth() && isNotPending();
      allow update, delete: if isAuth() && isManagement();
    }
  }
}
