# Content Studio — direct Turso/libSQL access (same DB as galaxy-cmo-dashboard)
VITE_TURSO_DATABASE_URL=libsql://your-db.turso.io
VITE_TURSO_AUTH_TOKEN=your_turso_auth_token

# Content Studio — social sync (optional, leave unset to keep a platform "Not connected")
